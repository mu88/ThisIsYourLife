<?xml version="1.0" encoding="utf-8"?>
<Configuration>
  <CodeCoverage>
    <ModulePaths>
      <Include>
        <ModulePath>.*BusinessServices\.dll$</ModulePath>
        <ModulePath>.*Persistence\.dll$</ModulePath>
        <ModulePath>.*Entities\.dll$</ModulePath>
        <ModulePath>.*DTO\.dll$</ModulePath>
        <ModulePath>.*Logging\.dll$</ModulePath>
        <ModulePath>.*WebApp\.dll$</ModulePath>
      </Include>
    </ModulePaths>
    <Sources>
      <Exclude>
        <Source>.*[\\/]App\.razor$</Source>
        <Source>.*[\\/]Error\.razor$</Source>
        <Source>.*[\\/]Routes\.razor$</Source>
      </Exclude>
    </Sources>
  </CodeCoverage>
</Configuration>
